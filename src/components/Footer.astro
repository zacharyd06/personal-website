---
import Icon from "./Icon.astro";
import { SITE, categories } from "../lib/blog-data.js";

const { flush = false } = Astro.props;
---

<footer class:list={[flush ? "mt-0" : "mt-24", "border-t border-border/60"]}>
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-12 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="font-serif text-lg font-semibold">{SITE.name}</div>
      {/* Fully linked description paragraph */}
      <p class="mt-3 max-w-sm text-sm leading-relaxed text-muted-foreground">
        Studying{" "}
        <a href={SITE.ibiomedUrl} target="_blank" rel="noopener noreferrer" class="underline decoration-border/40 text-foreground hover:decoration-primary transition-colors">iBioMed</a> 
        {" "}and{" "}
        <a href={SITE.neuroscienceUrl} target="_blank" rel="noopener noreferrer" class="underline decoration-border/40 text-foreground hover:decoration-primary transition-colors">Neuroscience</a> 
        {" "}at{" "}
        <a href={SITE.mcmasterUrl} target="_blank" rel="noopener noreferrer" class="underline decoration-border/40 text-foreground hover:decoration-primary transition-colors">McMaster University</a>. 
        Researching brain pathology, molecular mechanisms, and the tools to study them.
      </p>
      <div class="mt-4 flex items-center gap-3 text-muted-foreground">
        <a href="https://www.linkedin.com/in/zachary-droogendyk/" aria-label="Zachary Droogendyk on LinkedIn" class="hover:text-foreground"><Icon name="linkedin" class="h-4 w-4" /></a>
        <a href="https://orcid.org/0009-0000-9610-0476" aria-label="Zachary Droogendyk on ORCID" class="hover:text-foreground"><Icon name="orcid" class="h-4 w-4" /></a>
        <a href="https://github.com/zacharyd06" aria-label="Zachary Droogendyk on GitHub" class="hover:text-foreground"><Icon name="github" class="h-4 w-4" /></a>
        <a href="mailto:droogenz@mcmaster.ca" aria-label="Email" class="hover:text-foreground"><Icon name="mail" class="h-4 w-4" /></a>
      </div>
    </div>
    <div>
      <div class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Sections</div>
      <ul class="mt-3 space-y-2 text-sm">
        {
          categories.slice(0, 5).map((category) => (
            <li>
              <a href={`/categories/${category.slug}`} class="text-foreground/80 hover:text-foreground">
                {category.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <div class="text-xs font-medium uppercase tracking-wider text-muted-foreground">The site</div>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/home" class="hover:text-foreground">Home</a></li>
        <li><a href="/about" class="hover:text-foreground">About</a></li>
        <li><a href="/research" class="hover:text-foreground">Research</a></li>
        <li><a href="/clinical" class="hover:text-foreground">Clinical</a></li>
        <li><a href="/engineering" class="hover:text-foreground">Engineering</a></li>
        <li><a href="/curriculum-vitae" class="hover:text-foreground">Curriculum Vitae</a></li>
        <li><a href="/contact" class="hover:text-foreground">Contact</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-border/60">
    <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-2 px-5 py-5 text-xs text-muted-foreground sm:flex-row sm:items-center">
      <div>&copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.</div>
    </div>
  </div>
</footer>
